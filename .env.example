# ============================================================
# CloudSecurityApp — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Database (MySQL via XAMPP) ---
# For XAMPP local: root user, no password, database = CloudSecurityApp
DATABASE_URL=mysql+pymysql://root:@localhost/CloudSecurityApp

# For production MySQL server (fill in your credentials):
# DATABASE_URL=mysql+pymysql://CloudSecurityApp_user:STRONG_PASSWORD@your-db-host:3306/CloudSecurityApp

# --- API Security ---
# Comma-separated list of allowed CORS origins (NO trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# For production (replace with your real domain):
# ALLOWED_ORIGINS=https://app.yourdomain.com

# Salt for API key hashing (must match the hash stored in DB)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY_SALT=change-me-to-a-random-64-char-hex-string

# --- LLM (Groq) ---
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key_here

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_INGEST=10/minute
